# ── API (copy to apps/api/.env) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/resolvd
BETTER_AUTH_SECRET=replace-with-32-byte-base64-secret
BETTER_AUTH_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# CORS origins for browser clients (admin UIs). Leave blank in dev.
ADMIN_DIRECTUS_URL=
ADMIN_UI_URL=

# Seed passwords (required for `npm run db:seed`; script refuses without them)
SEED_ADMIN_EMAIL=marius@resolvd.no
SEED_ADMIN_PASSWORD=changeme
SEED_DEMO_OWNER_EMAIL=demo@rorleggeren.no
SEED_DEMO_OWNER_PASSWORD=changeme
SEED_DEMO_EMPLOYEE_EMAIL=jonas@rorleggeren.no
SEED_DEMO_EMPLOYEE_PASSWORD=changeme

# ── Mobile (copy to apps/mobile/.env) ──
EXPO_PUBLIC_API_URL=http://localhost:3000
