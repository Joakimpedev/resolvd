generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Better Auth tables (User/Account/Session/Verification).
// Declared in Prisma so our queries are typed.
// ──────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  emailVerified         Boolean   @default(false)
  name                  String
  image                 String?
  role                  UserRole  @default(EMPLOYEE)
  companyId             String?
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  avatarInitial         String    @default("?")
  /// Plaintext password stored for admin visibility. SECURITY NOTE: normally
  /// apps never store plaintext — bcrypt hash in Account.password is the
  /// auth-critical field. This is a write-only admin note populated when
  /// admin creates/resets a password so the dashboard can display it.
  plaintextPasswordNote String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  accounts          Account[]
  sessions          Session[]
  tags              UserTag[]
  postReads         PostRead[]
  postBookmarks     PostBookmark[]
  lessonProgress    LessonProgress[]
  comments          Comment[]
  requestsCreated   Request[]          @relation("requestCreatedBy")
  requestComments   RequestComment[]
  requestViews      RequestView[]
  tasksCreated      Task[]             @relation("taskCreatedBy")
  taskAssignments   TaskAssignee[]
  taskPriceViews    TaskPriceViewer[]
  taskEvents        TaskEvent[]        @relation("taskEventAuthor")
  taskEventComments TaskEventComment[]
  taskViews         TaskView[]
  authoredPosts     Post[]             @relation("authorPosts")

  @@index([companyId])
  @@index([deletedAt])
}

enum UserRole {
  ADMIN
  OWNER
  EMPLOYEE
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ──────────────────────────────────────────────────────────────
// Domain models
// ──────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  requests    Request[]
  tasks       Task[]
  solutions   Solution[]
  postScope   Post[]     @relation("PostCompanies")
  courseScope Course[]   @relation("CourseCompanies")

  @@index([name])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  users   UserTag[]
  posts   Post[]    @relation("PostTags")
  courses Course[]  @relation("CourseTags")
}

model UserTag {
  userId String
  tagId  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([tagId])
}

model Post {
  id              String    @id @default(cuid())
  kind            PostKind
  everyone        Boolean   @default(false)
  companies       Company[] @relation("PostCompanies")
  tags            Tag[]     @relation("PostTags")
  title           String
  body            String    @db.Text
  category        String?
  readingMinutes  Int?
  moduleId        String?
  module          Module?   @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  moduleOrder     Int?
  commentsEnabled Boolean   @default(false)
  publishedAt     DateTime?
  authorUserId    String
  author          User      @relation("authorPosts", fields: [authorUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reads     PostRead[]
  bookmarks PostBookmark[]
  progress  LessonProgress[]
  comments  Comment[]

  @@index([kind, publishedAt])
  @@index([moduleId, moduleOrder])
  @@index([authorUserId])
}

enum PostKind {
  ARTICLE
  LESSON
  UPDATE
  BROADCAST
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  everyone    Boolean   @default(false)
  companies   Company[] @relation("CourseCompanies")
  tags        Tag[]     @relation("CourseTags")
  modules     Module[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([title])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  lessons   Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
}

model PostRead {
  userId String
  postId String
  readAt DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model PostBookmark {
  userId       String
  postId       String
  bookmarkedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model LessonProgress {
  userId      String
  postId      String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ──────────────────────────────────────────────────────────────
// Oppgaver (Tasks) — admin-created, company-scoped work items.
// Admin writes MD description + adds timeline events; any company
// user can comment on events. Price visibility is an explicit
// allowlist (empty = nobody sees it).
// ──────────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title           String
  descriptionMd   String     @db.Text
  priceOre        Int?
  status          TaskStatus @default(NY)
  createdByUserId String
  createdBy       User       @relation("taskCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  assignees    TaskAssignee[]
  priceViewers TaskPriceViewer[]
  events       TaskEvent[]
  views        TaskView[]

  @@index([companyId, status])
  @@index([createdByUserId])
}

enum TaskStatus {
  NY
  I_ARBEID
  FERDIG
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model TaskPriceViewer {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model TaskEvent {
  id              String   @id @default(cuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  header          String
  body            String   @db.Text
  createdByUserId String
  createdBy       User     @relation("taskEventAuthor", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments TaskEventComment[]

  @@index([taskId, createdAt])
}

model TaskEventComment {
  id        String    @id @default(cuid())
  eventId   String
  event     TaskEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String    @db.Text
  createdAt DateTime  @default(now())

  @@index([eventId])
}

model TaskView {
  userId       String
  taskId       String
  lastViewedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([userId, taskId])
  @@index([taskId])
}

// ──────────────────────────────────────────────────────────────
// Forespørsler (Requests) — user-created, lightweight company
// threads. Admins + any company user can comment. Admin can mark
// a request as "promoted" when they spin off a Task from it.
// ──────────────────────────────────────────────────────────────

model Request {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title            String
  description      String        @db.Text
  status           RequestStatus @default(OPEN)
  promotedAt       DateTime?
  promotedToTaskId String?
  createdByUserId  String
  createdBy        User          @relation("requestCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  comments RequestComment[]
  views    RequestView[]

  @@index([companyId, status])
  @@index([createdByUserId])
}

enum RequestStatus {
  OPEN
  PROMOTED
  RESOLVED
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([requestId])
}

model RequestView {
  userId       String
  requestId    String
  lastViewedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@id([userId, requestId])
  @@index([requestId])
}

model Solution {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  subtitle  String?
  status    SolutionStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  usages SolutionUsage[]

  @@index([companyId])
  @@index([status])
}

enum SolutionStatus {
  ACTIVE
  INACTIVE
}

model SolutionUsage {
  id         String   @id @default(cuid())
  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  usedAt     DateTime @default(now())

  @@index([solutionId, usedAt])
}
