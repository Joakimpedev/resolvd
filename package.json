{
  "name": "resolvd-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@resolvd/mobile",
    "api": "npm run dev --workspace=@resolvd/api",
    "db:push": "npm run db:push --workspace=@resolvd/api",
    "db:seed": "npm run db:seed --workspace=@resolvd/api",
    "db:studio": "npm run db:studio --workspace=@resolvd/api",
    "db:generate": "npm run db:generate --workspace=@resolvd/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "postinstall": "node scripts/fix-expo-junction.mjs"
  }
}
